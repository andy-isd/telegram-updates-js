{
  "name": "telegram-updates-js",
  "version": "1.0.0",
  "description": "Get updates from a Telegram channel in a Node.js daemon.",
  "main": "tgupdates.js",
  "scripts": {
    "run": "node tgupdates.js",
    "check": "node --check tgupdates.js",
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 delete ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "update": "npm run stop; git pull; npm run start"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "telegram": "^2.26.16"
  }
}
